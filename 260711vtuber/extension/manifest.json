{
  "manifest_version": 3,
  "name": "치지직 키리누키 프롬프트",
  "version": "1.3.0",
  "description": "치지직 방송인을 최신 공식 정책 링크와 매칭해 말의 세션 앵커와 Codex 작업 폴더를 만듭니다.",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://chzzk.naver.com/*",
    "https://api.chzzk.naver.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "치지직 키리누키 프롬프트 열기"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chzzk.naver.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
