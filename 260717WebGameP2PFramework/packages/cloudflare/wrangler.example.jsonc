{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "relayplay-example",
  "main": "src/worker-entry.ts",
  "compatibility_date": "2026-07-17",
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOMS",
        "class_name": "GameRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["GameRoom"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
