{
  "name": "@relayplay/cloudflare",
  "version": "0.1.0",
  "description": "Cloudflare Worker and Durable Object adapter for RelayPlay.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "wrangler.example.jsonc"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run test"
  },
  "dependencies": {
    "@relayplay/core": "0.1.0",
    "@relayplay/server": "0.1.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
